@page "/login"
@layout LoginLayout
@attribute [AllowAnonymous]


<PageTitle>Login</PageTitle>

<div class="row justify-content-center">
    <div class="col-md-5">
        <h1 class="h3 mb-3">Sign in</h1>
        @if (Error == "1")
        {
            <div class="alert alert-danger">Invalid email or password.</div>
        }
        <form method="post" action="/account/login">
            <input type="hidden" name="returnUrl" value="@ReturnUrl" />
            <div class="mb-3">
                <label class="form-label" for="email">Email</label>
                <input class="form-control" id="email" name="email" type="email" required autocomplete="username" />
            </div>
            <div class="mb-3">
                <label class="form-label" for="password">Password</label>
                <input class="form-control" id="password" name="password" type="password" required autocomplete="current-password" />
            </div>
            <button class="btn btn-primary w-100" type="submit">Login</button>
        </form>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "error")] public string? Error { get; set; }
    [SupplyParameterFromQuery(Name = "returnUrl")] public string? ReturnUrl { get; set; }
}
